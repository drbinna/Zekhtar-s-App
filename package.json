{
  "name": "zekthar",
  "version": "1.0.5",
  "description": "Zek'thar — an alien scientist who can see your screen",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"node --watch server.js\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:server": "node --watch server.js",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@nut-tree-fork/nut-js": "^4.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "concurrently": "^8.2.2",
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^7.2.0"
  }
}
