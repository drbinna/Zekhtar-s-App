    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "concurrently": "^8.2.2",
    "electron": "^37.0.0",
    "wait-on": "^7.2.0"
  }
}
