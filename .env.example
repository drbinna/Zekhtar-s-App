# Anam — get your key from https://lab.anam.ai/api-keys
ANAM_API_KEY=your-anam-api-key-here
PERSONA_ID=your-persona-id-here

# Claude — used by /api/vision/chat for screen reasoning + computer-use.
# Option A (preferred): AWS Bedrock. Set a Bedrock API key and region; the app
# will route all Claude calls (Fable 5 + Haiku 4.5) through Bedrock.
# Requires Bedrock model access for Anthropic models in your AWS account.
AWS_BEDROCK_API_KEY=your-bedrock-api-key-here
AWS_REGION=us-east-1

# Option B (fallback for local dev): direct Anthropic API.
# Used only if AWS_BEDROCK_API_KEY is unset.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Server port
PORT=3000
